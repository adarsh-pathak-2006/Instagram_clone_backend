# Django Settings
SECRET_KEY=your_super_secret_key_here
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.com

# Neon DB / PostgreSQL
DATABASE_URL=postgres://user:password@hostname:5432/dbname?sslmode=require

# Supabase Storage / S3 Settings
# (Get these from your Supabase Dashboard -> Project Settings -> Storage -> S3 Credentials)
AWS_ACCESS_KEY_ID=your_supabase_access_key_id
AWS_SECRET_ACCESS_KEY=your_supabase_secret_access_key
AWS_STORAGE_BUCKET_NAME=your_supabase_bucket_name
AWS_S3_ENDPOINT_URL=https://your-project-ref.supabase.co/storage/v1/s3
AWS_S3_REGION_NAME=your_supabase_region (e.g. us-east-1)
